      {
        "parameters": {
          "jsCode": "const b64 = $json.fileBase64 || null;\nlet warning = false;\nlet pages = null;\n\ntry {\n  if (b64) {\n    const text = Buffer.from(b64, 'base64').toString('binary');\n    const matches = text.match(/\\/Type\\s*\\/Page[^s]/g);\n    pages = matches ? matches.length : null;\n    warning = pages && pages > 30;\n  }\n} catch (e) {}\n\nreturn [{\n  json: {\n    ...$json,\n    pages,\n    warningOverLimit: warning\n  }\n}];"
        },
