        "parameters": {
          "jsCode": "const designSpec = {\n  title: \"Prototype from Paper\",\n  screens: [\n    { id: \"home\", type: \"screen\", elements: [\"header\", \"upload box\", \"cta button\"] },\n    { id: \"results\", type: \"screen\", elements: [\"summary text\", \"user persona cards\"] }\n  ],\n  personas: [\n    { name: \"Early Adopter\", needs: \"fast testing\", goal: \"see if product idea resonates\" }\n  ]\n};\n\nreturn [{\n  json: {\n    ...$json,\n    designspec: JSON.stringify(designSpec, null, 2),\n    state: \"DONE\"\n  }\n}];"
