        "jsCode": "const crypto = require(\"crypto\");\n\nfunction normalizeWhitespace(input) {\n  return String(input || \"\").replace(/\\s+/g, \" \").trim();\n}\n\nfunction canonicalUrl(url) {\n  try {\n    const u = new URL(String(url || \"\").trim());\n    const DROP_PARAMS = new Set([\n      \"utm_source\",\"utm_medium\",\"utm_campaign\",\"utm_term\",\"utm_content\",\n      \"fbclid\",\"gclid\",\"igshid\",\"mc_cid\",\"mc_eid\"\n    ]);\n\n    // Remove tracking params\n    for (const k of [...u.searchParams.keys()]) {\n      if (DROP_PARAMS.has(String(k).toLowerCase())) u.searchParams.delete(k);\n    }\n\n    // Sort params\n    const entries = [...u.searchParams.entries()].sort(([a],[b]) => a.localeCompare(b));\n    u.search = \"\";\n    for (const [k,v] of entries) u.searchParams.append(k, v);\n\n    // Normalize trailing slash\n    u.pathname = u.pathname.replace(/\\/+$/, \"\");\n    return u.toString();\n  } catch {\n    return String(url || \"\").trim();\n  }\n}\n\nfunction sha256Hex(input) {\n  return crypto.createHash(\"sha256\").update(input, \"utf8\").digest(\"hex\");\n}\n\nfunction must(value, name) {\n  if (value === undefined || value === null || value === \"\") {\n    throw new Error(`Missing required field: ${name}`);\n  }\n  return value;\n}\n\nreturn $input.all().map((item) => {\n  const j = item.json || {};\n\n  // These should already be present from \"Normalize + Reattach source_id\"\n  const source_id = j.source_id ?? null;\n\n  // HARD FAIL if source_id is missing to prevent bad inserts\n  must(source_id, \"source_id\");\n\n  const url = must(j.url, \"url\");\n  const title = must(j.title, \"title\");\n\n  // Your workflow uses $json.content in the model prompt; ensure it exists.\n  const content = normalizeWhitespace(j.content ?? j.summary ?? \"\");\n\n  // published_at: keep as-is (string or null). Model can output published_date if needed.\n  const published_at = j.published_at ?? null;\n\n  const canonical_url = canonicalUrl(url);\n  const normalized_title = normalizeWhitespace(title).toLowerCase();\n  const normalized_content = content.toLowerCase();\n\n  // Source-aware hash so same URL/title/content across different sources doesn't collide\n  const hash_material = [\"v1\", String(source_id), canonical_url, normalized_title, normalized_content].join(\"|\");\n  const content_hash = sha256Hex(hash_material);\n\n  return {\n    json: {\n      ...j,\n      url: canonical_url,\n      title: normalizeWhitespace(title),\n      content,                 // <-- downstream LLM reads this\n      published_at,            // <-- ISO or raw string from scraper\n      content_hash,\n      n8n_content_hash: content_hash,\n      source_id                // <-- guaranteed\n    }\n  };\n});\n"
