    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function domainFromAnyUrl(u) {\n  if (!u) return \"\";\n  let s = String(u).trim();\n\n  // Support schemeless URLs like //thedigital.gov.ua/news/...\n  if (s.startsWith(\"//\")) s = s.slice(2);\n\n  // Strip protocol if present\n  s = s.replace(/^https?:\\/\\//i, \"\");\n\n  // Domain is everything up to first / ? #\n  const m = s.match(/^([^\\/\\?#]+)/);\n  if (!m) return \"\";\n\n  return m[1].toLowerCase().replace(/^www\\./, \"\");\n}\n\n// 1) Build domain -> source_id map from Get row(s)\nconst rows = $items(\"Get row(s)\", 0) ?? [];\nconst domainToSourceId = {};\n\nfor (const r of rows) {\n  const newsURL = r.json.newsURL;\n  const domain = domainFromAnyUrl(newsURL);\n  if (!domain) continue;\n\n  domainToSourceId[domain] = r.json.source_id;\n}\n\n// 2) Get article url from current item\nconst articleUrl = $json.url;\nconst articleDomain = domainFromAnyUrl(articleUrl);\n\nif (!articleDomain) {\n  throw new Error(`Cannot extract domain from article url: ${articleUrl}`);\n}\n\nconst source_id = domainToSourceId[articleDomain];\nif (!source_id) {\n  const known = Object.keys(domainToSourceId).sort().join(\", \");\n  throw new Error(`No source_id for domain \"${articleDomain}\". Known domains: ${known}`);\n}\n\n// 3) Attach and return\nreturn {\n  ...$json,\n  source_id,\n  __matched_domain: articleDomain, // keep for debugging; remove later if you want\n};\n"
      },
