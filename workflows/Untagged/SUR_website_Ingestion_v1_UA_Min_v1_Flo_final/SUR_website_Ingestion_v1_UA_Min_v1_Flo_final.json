    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function pad2(n) { return String(n).padStart(2, \"0\"); }\n\nconst UA_MONTHS = {\n  \"січня\": 1, \"січень\": 1,\n  \"лютого\": 2, \"лютий\": 2,\n  \"березня\": 3, \"березень\": 3,\n  \"квітня\": 4, \"квітень\": 4,\n  \"травня\": 5, \"травень\": 5,\n  \"червня\": 6, \"червень\": 6,\n  \"липня\": 7, \"липень\": 7,\n  \"серпня\": 8, \"серпень\": 8,\n  \"вересня\": 9, \"вересень\": 9,\n  \"жовтня\": 10, \"жовтень\": 10,\n  \"листопада\": 11, \"листопад\": 11,\n  \"грудня\": 12, \"грудень\": 12,\n};\n\nfunction toIsoDateOnly(y, m, d) {\n  return `${y}-${pad2(m)}-${pad2(d)}`;\n}\n\nfunction parseDate(raw) {\n  if (!raw) return null;\n  const s = String(raw).trim();\n\n  // ISO already\n  if (/^\\d{4}-\\d{2}-\\d{2}/.test(s)) return s;\n\n  // DD.MM.YYYY or D.M.YYYY\n  let m = s.match(/^(\\d{1,2})\\.(\\d{1,2})\\.(\\d{4})$/);\n  if (m) {\n    const d = parseInt(m[1], 10);\n    const mo = parseInt(m[2], 10);\n    const y = parseInt(m[3], 10);\n    return toIsoDateOnly(y, mo, d);\n  }\n\n  // Ukrainian text: \"7 лютого 2026\"\n  m = s\n    .toLowerCase()\n    .replace(/,/g, \" \")\n    .replace(/\\s+/g, \" \")\n    .match(/^(\\d{1,2})\\s+([а-щьюяіїєґ]+)\\s+(\\d{4})/i);\n\n  if (m) {\n    const d = parseInt(m[1], 10);\n    const monthWord = m[2];\n    const y = parseInt(m[3], 10);\n    const mo = UA_MONTHS[monthWord];\n    if (mo) return toIsoDateOnly(y, mo, d);\n  }\n\n  return null;\n}\n\nconst raw = $json.date ?? $json.published_at ?? $json.published_date ?? null;\nconst iso = parseDate(raw);\n\nif (!iso) {\n  return {\n    ...$json,\n    __date_parse_failed: true,\n    __raw_date_value: raw,\n  };\n}\n\nreturn {\n  ...$json,\n  published_at_iso: iso,\n  // overwrite ambiguous fields so downstream never mis-parses\n  date: iso,\n  published_at: iso,\n};\n"
