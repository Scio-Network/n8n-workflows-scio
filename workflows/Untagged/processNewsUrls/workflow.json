    {
      "parameters": {
        "jsCode": "// 1. Get ALL items from the Start node (List A)\nconst itemsA = $('Start').all();\n\n// 2. Get the items that passed the \"If\" node (List B)\nconst itemsB = $('If').all();\n\n// 3. Helper to normalize URLs\nconst clean = (url) => {\n  if (!url) return '';\n  return url.toLowerCase()\n    .replace(/^https?:\\/\\//, '')\n    .replace(/^www\\./, '')\n    .replace(/\\/$/, '')\n    .trim();\n};\n\n// 4. Build a set of cleaned URLs from B \n// (Leaving this exactly as you originally had it, using source_url)\nconst urlsInB = new Set(itemsB.map(item => clean(item.json.source_url)));\n\n// 5. Filter items from A where the URL exists in B\nconst matches = itemsA.filter(item => {\n  // THIS is the only line that changed to match your new Start node structure\n  const cleanedA = clean(item.json.verified_news?.url); \n  return urlsInB.has(cleanedA);\n});\n\n// 6. Return matched items \nreturn matches.map(item => {\n  return {\n    json: item.json.verified_news\n  };\n});"
      },
