      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Get the result from Supabase (the current node input)\nconst supabaseRow = $json;\n\n// 2. Reach back to get the hash from the \"Normalize website items\" node\n// This ensures the hash is NEVER null, allowing the Merge node to find it.\nconst originalHash = $node[\"Normalize website items\"].json[\"n8n_content_hash\"];\n\n// 3. Determine if it's a duplicate based on whether Supabase returned an ID\nconst isDuplicate = !!(supabaseRow && supabaseRow.id);\n\nreturn {\n  json: {\n    n8n_content_hash: originalHash, // This connects back to the Merge node\n    __is_duplicate: isDuplicate,\n    __dup_row_id: supabaseRow.id || null\n  }\n};"
      },
