        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "// Run Once for Each Item ✅\n// Normalizes website-scraped article + computes stable SHA-256 hash for deduping\n\nconst crypto = require('crypto');\n\nfunction normalizeWhitespace(s) {\n  return String(s ?? '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction canonicalUrl(url) {\n  const raw = String(url ?? '').trim();\n  if (!raw) return raw;\n\n  try {\n    const u = new URL(raw);\n\n    // Drop common tracking params\n    const drop = new Set([\n      'utm_source','utm_medium','utm_campaign','utm_term','utm_content',\n      'at_medium','at_campaign','at_custom1','at_custom2','at_custom3',\n      'fbclid','gclid','igshid','mc_cid','mc_eid'\n    ]);\n\n    for (const k of [...u.searchParams.keys()]) {\n      if (drop.has(k.toLowerCase())) u.searchParams.delete(k);\n    }\n\n    // Sort remaining params for stability\n    const params = [...u.searchParams.entries()].sort(([a], [b]) => a.localeCompare(b));\n    u.search = '';\n    for (const [k, v] of params) u.searchParams.append(k, v);\n\n    // Normalize trailing slashes\n    u.pathname = u.pathname.replace(/\\/+$/, '');\n\n    return u.toString();\n  } catch {\n    return raw;\n  }\n}\n\nfunction sha256Hex(input) {\n  return crypto.createHash('sha256').update(input, 'utf8').digest('hex');\n}\n\n// ---- INPUT MAPPING (current item) ----\nconst source_id = $json.source_id ?? ''; \nconst urlCanon = canonicalUrl($json.link ?? ''); // \nconst titleNorm = normalizeWhitespace($json.title ?? '');\nconst contentNorm = normalizeWhitespace($json.content ?? '');\n\n// Stable hash material (don’t depend on LLM output)\nconst hashMaterial = [\n  'v1',\n  source_id,\n  urlCanon,\n  titleNorm.toLowerCase(),\n  contentNorm.toLowerCase()\n].join('|');\n\nconst n8n_content_hash = sha256Hex(hashMaterial);\n\n// IMPORTANT in per-item mode: return a SINGLE item object\nreturn {\n  json: {\n    ...$json,\n    n8n_content_hash,\n    content_hash: n8n_content_hash // optional mirror\n  },\n};\n"
        },
