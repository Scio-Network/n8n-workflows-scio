      {
        "parameters": {
          "jsCode": "const dateFields = [\n  'created_at',\n  'updated_at',\n  'ingested_at',\n  'validated_at',\n  'embedded_at',\n  'next_retry_at',\n];\n\nlet latestDate = null;\nlet latestTime = -Infinity;\n\nfor (const item of items) {\n  for (const field of dateFields) {\n    const value = item.json[field];\n    if (!value) continue;\n\n    const time = new Date(value).getTime();\n    if (!isNaN(time) && time > latestTime) {\n      latestTime = time;\n      latestDate = value;\n    }\n  }\n}\n\nreturn [\n  {\n    json: {\n      latestDate,\n    },\n  },\n];"
        },
