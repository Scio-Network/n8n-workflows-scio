          "jsCode": "// Get the stakeholder ID from the Supabase node\nconst stakeholder = $items(\"Get a row1\")[0]?.json;\n\nif (!stakeholder?.id) {\n  throw new Error(\"Missing stakeholder.id from Supabase node 'Get a row1'\");\n}\n\nconst sourceId = stakeholder.id;\n\n// Transform the items\nreturn $input.all().map((item) => {\n  return {\n    json: {\n      content: item.json.data.content,\n      date: item.json.data.date,\n      link: item.json.data.link,\n      title: item.json.data.title,\n      source_id: sourceId\n    }\n  };\n});"
