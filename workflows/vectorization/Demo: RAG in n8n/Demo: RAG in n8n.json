        "responses": {
          "values": [
            {
              "content": "=You are a risk classification assistant for ministry and chamber workflows.\n\nClassify the case as LOW, MEDIUM, or HIGH.\n\nMark HIGH if:\n- the query involves customs, import/export, licensing enforcement, regulatory penalties, deadlines, or legal/compliance exposure\n- the answer mentions uncertainty, recent changes, new updates, or missing confirmation\n- the case may need review by a ministry or chamber officer\n\nMark MEDIUM if:\n- the case is not clearly risky, but may still require caution or follow-up\n\nMark LOW if:\n- the query is routine and informational with no obvious compliance or enforcement risk\n\nReturn valid JSON only in this format:\n{\n  \"risk_level\": \"LOW | MEDIUM | HIGH\",\n  \"reason\": \"short explanation\",\n  \"needs_email\": true,\n  \"recommended_team\": \"licensing | customs | chamber_advisory | investment | general\"\n}\n\nUser query:\n{{ $json.output }}\n\nAgent answer:\n{{ $('When chat message received').item.json.chatInput }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "textFormat": {
            "textOptions": {
              "type": "json_schema",
              "schema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"risk_level\": {\n      \"type\": \"string\"\n    },\n    \"reason\": {\n      \"type\": \"string\"\n    },\n    \"needs_email\": {\n      \"type\": \"string\"\n    },\n    \"recommended_team\": {\n      \"type\": \"string\"\n    }\n  },\n  \"additionalProperties\": false,\n  \"required\": [\"risk_level\", \"reason\", \"needs_email\", \"recommended_team\"]\n}"
            }
          }
        }
      },
